# LLM Configuration
LLM_PROVIDER=kimi-coding
LLM_API_KEY=sk-your-kimi-key
LLM_MODEL=kimi-for-coding
LLM_BASE_URL=https://api.kimi.com/coding

# Neo AI Configuration
NEODOMAIN_BASE_URL=https://api.neodomain.ai/v1
NEODOMAIN_ACCESS_TOKEN=your-neo-ai-token
NEODOMAIN_DEFAULT_MODEL=gemini-3-pro-image-preview
NEODOMAIN_DEFAULT_SIZE=2K

# Test mode: set to true to skip AI generation and wait for manual uploads
SKIP_AI_GENERATION=false

# Storage
STORAGE_BASE_DIR=./storage
MAX_TASK_AGE_DAYS=7

# Templates
TEMPLATES_DIR=./app/templates_data

# App
APP_HOST=0.0.0.0
APP_PORT=3000
DEBUG=false
